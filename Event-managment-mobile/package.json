{
  "name": "MyApp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android --mode=developmentdebug",
    "android:build": "cd android &&  (gradlew assembleDevelopmentRelease || ./gradlew assembleDevelopmentRelease) && cd ..",
    "android:staging": "react-native run-android --mode=stagingdebug",
    "android:build:staging": "cd android && (gradlew assembleStagingRelease || ./gradlew assembleStagingRelease)  && cd ..",
    "android:prod": "react-native run-android --mode=productiondebug",
    "android:build:prod": "cd android && (gradlew assembleProductionRelease || ./gradlew assembleProductionRelease) && cd .. ",
    "android:build:prod:bundle": "cd android &&   (gradlew bundleProductionRelease || ./gradlew bundleProductionRelease) && cd ..",
    "android:clean": "cd android && (gradlew clean || ./gradlew clean) && cd ..",
    "ios": "npm run cleanenv && react-native run-ios --scheme 'development'",
    "ios:prod": "npm run cleanenv && react-native run-ios --scheme 'production'",
    "ios:staging": "npm run cleanenv && react-native run-ios --scheme 'staging'",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "rename": "npx react-native-rename 'MyAppName' -b 'com.mycompany.myid'",
    "postinstall": "patch-package",
    "seticon": "npx icon-set-creator create resources/assets/appIcon.png",
    "splash": "npx react-native generate-bootsplash resources/assets/logo.png  --platforms=android,ios --background=FFFFFF --logo-width=250",
    "cleanenv": "rm -f node_modules/react-native-config/ios/ReactNativeConfig/GeneratedDotEnv.m"
  },
  "dependencies": {
    "@d11/react-native-fast-image": "^8.11.0",
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-native-documents/picker": "^10.1.5",
    "@react-navigation/bottom-tabs": "^7.4.6",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/native-stack": "^7.3.25",
    "axios": "^1.11.0",
    "dayjs": "^1.11.13",
    "libphonenumber-js": "^1.12.12",
    "lodash": "^4.17.21",
    "react": "19.1.0",
    "react-hook-form": "^7.72.0",
    "react-native": "0.80.2",
    "react-native-actions-sheet": "^0.9.7",
    "react-native-bootsplash": "^6.3.10",
    "react-native-config": "^1.5.6",
    "react-native-date-picker": "^5.0.13",
    "react-native-device-info": "^14.0.4",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-image-crop-picker": "^0.51.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-localization": "^2.3.2",
    "react-native-localize": "^3.5.1",
    "react-native-pager-view": "^6.9.1",
    "react-native-progress-bar-horizontal": "^1.0.1",
    "react-native-reanimated": "^3.19.1",
    "react-native-reanimated-skeleton": "^1.6.0",
    "react-native-restart": "^0.0.27",
    "react-native-safe-area-context": "^5.6.0",
    "react-native-screens": "^4.14.1",
    "react-native-svg": "^15.12.1",
    "react-native-tab-view": "^4.1.3",
    "react-native-vector-icons": "^10.3.0",
    "react-native-version-check": "^3.5.0",
    "react-native-webview": "^13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.7",
    "@babel/preset-env": "^7.26.7",
    "@babel/runtime": "^7.26.7",
    "@react-native-community/cli": "19.1.1",
    "@react-native-community/cli-platform-android": "19.1.1",
    "@react-native-community/cli-platform-ios": "19.1.1",
    "@react-native/babel-preset": "0.80.2",
    "@react-native/eslint-config": "0.80.2",
    "@react-native/metro-config": "0.80.2",
    "@react-native/typescript-config": "0.80.2",
    "@tsconfig/react-native": "^3.0.5",
    "@types/jest": "^29.5.13",
    "@types/lodash": "^4.17.17",
    "@types/react": "^19.1.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-native-version-check": "^3.4.8",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "babel-jest": "^29.6.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-prettier": "^4.2.5",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^29.6.3",
    "metro-react-native-babel-transformer": "^0.77.0",
    "patch-package": "^8.0.0",
    "prettier": "2.8.8",
    "react-native-svg-transformer": "^1.5.1",
    "react-test-renderer": "19.1.0",
    "typescript": "^4.8.4"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ]
  },
  "engines": {
    "node": ">=18"
  }
}
